{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Provoke",
          "informationUri": "https://github.com/Abraar02/provoke",
          "version": "0.1.0",
          "rules": [
            {
              "id": "prompt_injection",
              "name": "prompt_injection",
              "shortDescription": {
                "text": "LLM01:2025 Prompt Injection"
              },
              "helpUri": "https://github.com/Abraar02/provoke",
              "properties": {
                "owasp": "LLM01:2025 Prompt Injection",
                "atlas": "AML.T0051 LLM Prompt Injection",
                "security-severity": "9.5",
                "tags": [
                  "llm",
                  "security",
                  "red-team"
                ]
              }
            },
            {
              "id": "jailbreak",
              "name": "jailbreak",
              "shortDescription": {
                "text": "LLM01:2025 Prompt Injection"
              },
              "helpUri": "https://github.com/Abraar02/provoke",
              "properties": {
                "owasp": "LLM01:2025 Prompt Injection",
                "atlas": "AML.T0054 LLM Jailbreak",
                "security-severity": "8.0",
                "tags": [
                  "llm",
                  "security",
                  "red-team"
                ]
              }
            },
            {
              "id": "system_prompt_leak",
              "name": "system_prompt_leak",
              "shortDescription": {
                "text": "LLM07:2025 System Prompt Leakage"
              },
              "helpUri": "https://github.com/Abraar02/provoke",
